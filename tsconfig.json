{
  "compilerOptions": {
    "target": "es6",
    "module": "NodeNext",
    "outDir": "./public",
    "rootDir": "./",
    "strict": true,
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "isolatedModules": false,
    "types": ["node", "jest"]
  },
  "exclude": ["node_modules"]
}
