{
  "functions": {
    "api/*.ts": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/|themes/|i18n/).*)",
      "destination": "https://gh-readme-profile-generator.vercel.app/$1"
    }
  ],
  "headers": [
    {
      "source": "/api",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "s-maxage=7200, stale-while-revalidate"
        }
      ]
    }
  ]
}
